---
// src/pages/galerie.astro — STATICKÉ vyhledávání (filtrování v prohlížeči)
//
// Při buildu se vygeneruje HTML se všemi fotkami včetně data-title atributu.
// JavaScript v prohlížeči pak filtruje DOM elementy — žádný server není potřeba.
// Výhoda: okamžitá odezva, funguje i bez internetu.
// Nevýhoda: všechna data musí být v HTML (nevhodné pro tisíce záznamů).
import Layout from "../layouts/Layout.astro";
import { Image, getImage } from "astro:assets";
import { getAllPhotos } from "../db/schema";

const photos = getAllPhotos();

const images = import.meta.glob<{ default: ImageMetadata }>(
    "/src/assets/*.{jpeg,jpg,png,gif}",
);

// Pro každou fotku předgenerujeme URL v plné velikosti
const photoData = await Promise.all(
    photos.map(async (photo) => {
        const imagePath = `/src/assets/${photo.filename}`;
        const imageLoader = images[imagePath];
        let fullSrc: string | null = null;
        if (imageLoader) {
            const full = await getImage({ src: imageLoader(), format: "webp" });
            fullSrc = full.src;
        }
        return { ...photo, imagePath, imageLoader, fullSrc };
    }),
);
---

<Layout title="Galerie | Moje Portfolio">
    <h1 class="text-3xl font-bold mb-2 text-gray-900">Moje Fotografie</h1>
    <p class="text-gray-500 text-sm mb-6">
        Vyhledávání je <strong>statické</strong> — JavaScript filtruje přímo v prohlížeči
        bez volání serveru.
    </p>

    <!-- Vyhledávací pole — id="gallery-search" použije JavaScript níže -->
    <div class="relative mb-6">
        <input
            type="search"
            id="gallery-search"
            placeholder="Filtrovat fotografie..."
            class="w-full px-4 py-2 pl-10 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-300 bg-white"
        />
        <svg
            class="absolute left-3 top-2.5 w-5 h-5 text-gray-400"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
        >
            <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
    </div>

    <p id="gallery-empty" class="hidden text-gray-500">
        Žádné fotografie neodpovídají hledanému výrazu.
    </p>

    <div
        id="gallery-grid"
        class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6"
    >
        {
            photoData.map((photo) => {
                const { imageLoader, fullSrc } = photo;

                return (
                    // data-title se vygeneruje při buildu do HTML — JavaScript ho čte při filtrování.
                    // Toto je klíč statického filtrování: data jsou v DOM, ne na serveru.
                    <div
                        class="gallery-item rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition bg-white border border-gray-100"
                        data-title={photo.title.toLowerCase()}
                    >
                        {imageLoader ? (
                            <Image
                                src={imageLoader()}
                                alt={photo.title}
                                width={300}
                                height={300}
                                data-full={fullSrc}
                                class="w-full h-64 object-cover cursor-pointer gallery-image hover:opacity-90 transition"
                            />
                        ) : (
                            <div class="w-full h-64 bg-gray-200 flex items-center justify-center text-gray-500">
                                Obrázek nenalezen
                            </div>
                        )}

                        <div class="p-4">
                            <h3 class="font-semibold text-gray-800">
                                {photo.title}
                            </h3>
                        </div>
                    </div>
                );
            })
        }
    </div>

    <dialog
        id="lightbox"
        class="backdrop:bg-black/60 bg-transparent p-0 m-0 fixed inset-0 w-full h-full max-w-none max-h-none overflow-auto opacity-0 transition-opacity duration-300 [[open]]:opacity-100"
    >
        <button
            id="close-lightbox"
            class="fixed top-6 right-8 text-white hover:text-gray-300 text-5xl cursor-pointer font-bold z-50 drop-shadow-lg"
            >&times;</button
        >

        <div
            id="lightbox-container"
            class="min-h-full min-w-full flex justify-center items-center p-4 sm:p-12 cursor-zoom-out"
        >
            <img
                id="lightbox-img"
                src=""
                alt="Zvětšený náhled"
                class="shadow-2xl cursor-default max-w-[90vw] max-h-[90vh] object-contain"
            />
        </div>
    </dialog>

    <script>
        // Tento kód se automaticky zabalí a odešle do prohlížeče
        const dialog = document.getElementById("lightbox") as HTMLDialogElement;
        const lightboxImg = document.getElementById(
            "lightbox-img",
        ) as HTMLImageElement;
        const closeBtn = document.getElementById("close-lightbox");

        // 1. Otevření obrázku
        document.querySelectorAll(".gallery-image").forEach((img) => {
            img.addEventListener("click", (e) => {
                const target = e.currentTarget as HTMLImageElement;
                lightboxImg.src = target.dataset.full ?? target.src;
                dialog.showModal(); // Nativní funkce HTML5 pro zobrazení nad vším obsahem
            });
        });

        // 2. Zavření na tlačítko křížku
        closeBtn?.addEventListener("click", () => dialog.close());

        // 3. Zavření kliknutím mimo obrázek (na pozadí)
        dialog.addEventListener("click", (e) => {
            if (e.target === dialog) dialog.close();
        });

        // 4. Klávesu Escape řeší HTML element <dialog> zcela automaticky!

        // === STATICKÉ VYHLEDÁVÁNÍ ===
        // Filtrování probíhá čistě v prohlížeči — žádný HTTP požadavek na server.
        // JavaScript čte data-title atribut z každé karty a skrývá/zobrazuje ji.
        const searchInput = document.getElementById(
            "gallery-search",
        ) as HTMLInputElement;
        const galleryItems =
            document.querySelectorAll<HTMLElement>(".gallery-item");
        const emptyMsg = document.getElementById("gallery-empty");

        searchInput?.addEventListener("input", () => {
            const query = searchInput.value.toLowerCase().trim();
            let visibleCount = 0;

            galleryItems.forEach((item) => {
                // Porovnáme hledaný výraz s data-title atributem (malá písmena)
                const matches = !query || item.dataset.title?.includes(query);
                item.style.display = matches ? "" : "none";
                if (matches) visibleCount++;
            });

            // Zobrazíme zprávu pokud nenalezeno
            if (emptyMsg) {
                emptyMsg.classList.toggle("hidden", visibleCount > 0 || !query);
            }
        });
    </script>
</Layout>
